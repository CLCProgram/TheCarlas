#include <LCD_I2C.h>
#include <Wire.h>
int boton = 4;
// Default address of most PCF8574 modules, change address accordingly
LCD_I2C lcd(0x27, 20, 4);

uint8_t cuadrado[8] =
{
    0b11111,
    0b11111,
    0b11111,
    0b11111,
    0b11111,
    0b11111,
    0b11111,
    0b11111,
};

uint8_t blanco[8] =
{
    0b00000,
    0b00000,
    0b00000,
    0b00000,
    0b00000,
    0b00000,
    0b00000,
    0b00000,
};

void setup() {
 pinMode (4, INPUT);
  Wire.begin();
  lcd.begin(&Wire);
  lcd.display();
  lcd.backlight();
  lcd.createChar(0, cuadrado);
  lcd.createChar(1, blanco);
 } 

void loop() {
    
    lcd.setCursor(19,1);
    lcd.write(0);
    delay(1000);
    lcd.setCursor(19,1);
    lcd.write(1);
    lcd.setCursor(18,1);
    lcd.write(0);
    delay(1000);
    lcd.write(1);
    lcd.setCursor(17,1);
    lcd.write(0);
    delay(1000);
    
    
}
